# General
HOSTNAME=vault.yourdomain.tld
HTTP_PORT=80
HTTPS_PORT=443
SMTP_PORT=25
SMTP_SUBMISSION_PORT=587
FORCE_HTTPS_REDIRECT=true
LETSENCRYPT_ENABLED=false
DEPLOYMENT_MODE=install

# Registration — disable after creating your account(s)
PUBLIC_REGISTRATION_ENABLED=true

# Privacy
IP_LOGGING_ENABLED=false

# Email aliasing — comma-separated list of your private alias domains
PRIVATE_EMAIL_DOMAINS=alias.yourdomain.tld

# SMTP TLS (enable once you have a valid cert for your alias domain)
SMTP_TLS_ENABLED=false

# Secrets — generate with: openssl rand -base64 32
# These values are also read from /secrets/ files by the application.
POSTGRES_PASSWORD=
JWT_KEY=
DATA_PROTECTION_CERT_PASS=

# Database connection string
# IMPORTANT: use 127.0.0.1, not 'postgres' — all containers share localhost in a Podman Pod
ConnectionStrings__AliasServerDbContext=Host=127.0.0.1;Port=5432;Database=aliasvault;Username=aliasvault;Password=
